# JARVIS API Keys Template
# Copy this file to .env and fill in your keys

# AI Provider: "groq", "ollama", or "gemini"
AI_PROVIDER=groq
JARVIS_USER_NAME=Farhan Sir

# Groq API (FREE - get key from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (optional - requires billing enabled)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Model (for local AI - install from https://ollama.com)
OLLAMA_MODEL=llama3

# Telegram Configuration (for mobile access)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Calendar Configuration
# (Requires credentials.json in the project root)
GOOGLE_CALENDAR_ID=primary

# Notion Configuration
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
